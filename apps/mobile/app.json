{
  "expo": {
    "name": "Kakera Library",
    "slug": "kakera-library",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kakeralibrary.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.kakeralibrary.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        { "cameraPermission": "カメラを使用してバーコードをスキャンします" }
      ]
    ],
    "scheme": "kakera-library",
    "experiments": {
      "typedRoutes": true
    }
  }
}
