# PostgreSQL
POSTGRES_USER=kakera
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kakera_library

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# CORS (* allows all origins including mobile apps; restrict to your domain in production)
CORS_ORIGIN=*

# External APIs (optional; required for book/movie/drama metadata search)
TMDB_API_KEY=your-tmdb-api-key
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Web port (host)
WEB_PORT=3000
